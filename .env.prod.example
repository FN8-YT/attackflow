# =========================================================
# Variables de entorno — PRODUCCIÓN
# Copia este archivo a .env.prod en el VPS y rellena los valores.
# NUNCA subas .env.prod al repositorio.
# =========================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=genera-una-clave-con-python-secrets-token-hex-50
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tudominio.com,www.tudominio.com,TU_IP_DEL_VPS

# --- PostgreSQL ---
POSTGRES_DB=attackflow
POSTGRES_USER=attackflow
POSTGRES_PASSWORD=contraseña-muy-larga-y-aleatoria
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Email (Resend) ---
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=AttackFlow <noreply@tudominio.com>

# --- CORS (si tienes frontend separado) ---
CORS_ALLOWED_ORIGINS=https://tudominio.com

# --- Sentry (opcional, monitorización de errores) ---
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# --- Feature flags ---
DISABLE_PLAN_LIMITS=False
