# =========================================================
# Plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el `.env` al repositorio.
# =========================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-strong-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
POSTGRES_DB=securityaudit
POSTGRES_USER=securityaudit
POSTGRES_PASSWORD=securityaudit
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Feature flags ---
# True = todos los usuarios tienen acceso ilimitado (dev/testing).
# False = restricciones normales por plan (producción).
DISABLE_PLAN_LIMITS=True

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
